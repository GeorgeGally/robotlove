if [ "${1:-}" = "setup" ]; then
  path="${2:-}"
  if [ -z "$path" ]; then
    read -r -p "robots.txt path: " path
  fi
  # if a directory was given, look for robots.txt inside it
  if [ -d "$path" ]; then
    path="${path%/}/robots.txt"
  fi
  if [ ! -f "$path" ]; then
    echo "Error: $path not found" >&2
    exit 1
  fi
  echo "ROBOTS=$path" > "$CONF"
  echo "🤖 configured: $path"
  exit 0
fi

