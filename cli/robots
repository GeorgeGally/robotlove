    exit 1
  fi
  REPO=$(cat "$REPO_FILE")
  if [ ! -d "$REPO/.git" ]; then
    echo "Error: $REPO is not a git repo. Re-clone and run install.sh." >&2
    exit 1
  fi
  cd "$REPO"
  git pull
  DEST=$(command -v robots 2>/dev/null || echo "$HOME/bin/robots")
  cp cli/robots "$DEST"
  chmod +x "$DEST"
  DEST_DIR=$(dirname "$DEST")
  cp cli/llm.py "$DEST_DIR/llm.py"
  chmod +x "$DEST_DIR/llm.py" 2>/dev/null || true
  exec "$DEST" welcome
fi

