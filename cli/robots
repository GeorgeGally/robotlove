#!/bin/bash
set -euo pipefail

CONF="$HOME/.robots_conf"

load_robots_path() {
  if [ -f "$CONF" ]; then
    ROBOTS=$(grep '^ROBOTS=' "$CONF" | head -1 | cut -d= -f2-)
    if [ -n "$ROBOTS" ] && [ -f "$ROBOTS" ]; then
      return 0
    fi
  fi
  # auto-detect common locations
  for candidate in \
    "$HOME/public_html/robots.txt" \
    "$HOME/www/robots.txt" \
    "/var/www/html/robots.txt" \
    "/var/www/robots.txt" \
    "/usr/share/nginx/html/robots.txt"; do
    if [ -f "$candidate" ]; then
      ROBOTS="$candidate"
      return 0
    fi
  done
  # Dreamhost-style: $HOME/<domain>/robots.txt
  for d in "$HOME"/*/; do
    if [ -f "${d}robots.txt" ]; then
      ROBOTS="${d}robots.txt"
      return 0
    fi
  done
  echo "Error: robots.txt not found. Run: robots setup /path/to/robots.txt" >&2
  echo "       Or run: robots setup  (interactive prompt)" >&2
  exit 1
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | tr -s '-' | sed 's/^-//;s/-$//'
}

read_post() {
  python3 - "$1" <<'PYEOF'
import sys, re
path = sys.argv[1]
try:
    content = open(path).read()
except Exception:
    sys.exit(0)
lines = content.split('\n')
in_block = False
paths = []
for line in lines:
    s = line.strip()
    if re.match(r'^user-agent:\s*robots$', s, re.I):
        in_block = True
        continue
    if not in_block:
        continue
    if re.match(r'^user-agent:', s, re.I):
        break
    if s == '' and paths:
        break
    if re.match(r'^disallow:', s, re.I):
        p = s.split(':', 1)[1].strip()
        if p:
            paths.append(p)
for p in paths:
    print(f'Disallow: {p}')
PYEOF
}

write_post() {
  python3 - "$1" "$2" <<'PYEOF'
import sys, re, os, tempfile, shutil
path, new_disallow = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        content = f.read()
except FileNotFoundError:
    print(f'Error: {path} not found', file=sys.stderr)
    sys.exit(1)
# extract existing Disallow paths from Robots block
existing = []
match = re.search(r'(?im)^User-agent:\s*Robots\n((?:Disallow:[^\n]*\n)*)', content)
if match:
    for line in match.group(1).strip().split('\n'):
        m = re.match(r'(?i)Disallow:\s*(.*)', line.strip())
        if m:
            existing.append(m.group(1).strip())
# prepend new disallow, cap at 8 newest
all_paths = [new_disallow] + existing
all_paths = all_paths[:8]
# remove existing Robots block
content = re.sub(r'(?i)User-agent:\s*Robots\n(?:Disallow:[^\n]*\n)*\n?', '', content)
# build and prepend new block
block = 'User-agent: Robots\n' + ''.join(f'Disallow: {p}\n' for p in all_paths) + '\n'
content = block + content.lstrip('\n')
# atomic write
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))
try:
    with os.fdopen(fd, 'w') as f:
        f.write(content)
    os.chmod(tmp, 0o644)
    shutil.move(tmp, path)
except Exception as e:
    if os.path.exists(tmp):
        os.unlink(tmp)
    print(f'Error writing: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
}

