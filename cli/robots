SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd 2>/dev/null || echo "$(dirname "$0")")"
LLM_SCRIPT="$SCRIPT_DIR/llm.py"

find_llm() {
  if [ -f "$LLM_SCRIPT" ]; then
    echo "$LLM_SCRIPT"
    return 0
  fi
  local self
  self=$(command -v robots 2>/dev/null)
  if [ -n "$self" ]; then
    local dir; dir=$(dirname "$self")
    if [ -f "$dir/llm.py" ]; then
      echo "$dir/llm.py"
      return 0
    fi
  fi
  return 1
}

ai_setup() {
  local llm; llm=$(find_llm) || { echo "Error: llm.py not found" >&2; exit 1; }
  local env_file="$HOME/.robots_ai_env"
  local key="" prompt=""
  local default_prompt="Write a single path that could appear after Disallow: in a robots.txt file. This is a blog post — the entire post is the path itself. Lowercase, hyphens, no spaces, no file extension. Think: a place, a year, a version of something that didn't make it, a late-night thought, something started and abandoned. One line only. No explanation. Just the path."

  if [ -f "$env_file" ]; then
    key=$(grep '^OPENROUTER_API_KEY=' "$env_file" | head -1 | cut -d= -f2-)
    prompt=$(grep '^PROMPT_TEMPLATE=' "$env_file" | head -1 | cut -d= -f2-)
  fi

  echo ""
  echo "  ┌────────────────────────────────────────────┐"
  echo "  │           🤖  robots ai setup              │"
  echo "  └────────────────────────────────────────────┘"
  echo ""

  # --- API key ---
  echo "  ── api key ──────────────────────────────────"
  echo ""
  if [ -z "$key" ]; then
    echo "  Get one at: https://openrouter.ai/keys"
    read -r -p "  OpenRouter API key: " key
    [ -z "$key" ] && { echo ""; echo "  ✗  No key entered. Aborting."; exit 1; }
  else
    echo "  saved: ${key:0:12}…"
    echo ""
    read -r -p "  replace? [y/N] " yn
    if [ "$yn" = "y" ] || [ "$yn" = "Y" ]; then
      read -r -p "  OpenRouter API key: " key
    fi
  fi

  # --- Prompt ---
  echo ""
  echo "  ── prompt ───────────────────────────────────"
  echo ""
  if [ -z "$prompt" ]; then
    echo "  default:"
    echo "  $default_prompt"
    echo ""
    read -r -p "  customize? [y/N] " yn
    if [ "$yn" = "y" ] || [ "$yn" = "Y" ]; then
      read -r -p "  prompt: " prompt
      [ -z "$prompt" ] && prompt="$default_prompt"
    else
      prompt="$default_prompt"
    fi
  else
    echo "  Current prompt:"
    echo "    $prompt"
    echo ""
    read -r -p "  [e]dit / [r]eplace / [k]eep: " ans
    if [ "$ans" = "e" ] || [ "$ans" = "E" ]; then
      echo "  current:"
      echo "    $prompt"
      read -r -p "  edit (enter to keep): " edited
      [ -n "$edited" ] && prompt="$edited"
    elif [ "$ans" = "r" ] || [ "$ans" = "R" ]; then
      read -r -p "  new prompt: " prompt
      [ -z "$prompt" ] && prompt="$default_prompt"
    fi
  fi

  # --- Save ---
  cat > "$env_file" <<ENVEOF
OPENROUTER_API_KEY=$key
PROMPT_TEMPLATE=$prompt
ENVEOF
  chmod 600 "$env_file"
  echo ""
  echo "  ✓  saved to $env_file"
  echo ""

  # --- Test run ---
  echo "  ── test ─────────────────────────────────────"
  echo ""
  read -r -p "  run a test generation? [Y/n] " yn
  if [ "$yn" != "n" ] && [ "$yn" != "N" ]; then
    echo "  generating…"
    result=$(python3 "$llm" 2>/dev/null) || {
      echo "  ✗  generation failed. check your API key and network." >&2
      echo "     retry: robots ai" >&2
      exit 1
    }
    first_line=$(echo "$result" | head -1)
    echo ""
    echo "  →  $first_line"
    echo ""
    read -r -p "  post this? [y/N] " yn
    if [ "$yn" = "y" ] || [ "$yn" = "Y" ]; then
      local slug; slug=$(slugify "$first_line")
      write_post "$ROBOTS" "/${slug}/"
      echo "  🤖  posted: /${slug}/"
    fi
  fi

  # --- Cron ---
  echo ""
  echo "  ── cron ─────────────────────────────────────"
  echo ""
  local robots_path; robots_path=$(command -v robots 2>/dev/null || echo "$0")
  local cron_line="0 3 * * * ${robots_path} generate >> \$HOME/.robots-generate.log 2>&1"
  if crontab -l 2>/dev/null | grep -qF "$cron_line"; then
    echo "  cron: already installed"
  else
    echo "  1) auto-install"
    echo "  2) print instructions"
    read -r -p "  choose [1/2]: " choice
    if [ "$choice" = "2" ]; then
      echo ""
      echo "  add to crontab:"
      echo "  $cron_line"
    else
      local tmp; tmp=$(mktemp)
      crontab -l 2>/dev/null > "$tmp" || true
      echo "$cron_line" >> "$tmp"
      if crontab "$tmp" 2>/dev/null; then
        echo "  ✓  cron installed (daily at 3am)"
      else
        echo "  ✗  cron install failed" >&2
        echo ""
        echo "  add manually:"
        echo "  $cron_line"
      fi
      rm -f "$tmp"
    fi
  fi
  echo ""
  echo "  ─────────────────────────────────────────────"
  echo "  done. run 'robots generate' anytime."
  echo ""
}

