#!/bin/bash
set -euo pipefail

ROBOTS="/home/radarboy/radarboy.com/radarboy3000/robots.txt"

if [ $# -eq 0 ]; then
  if command -v curl &>/dev/null; then
    current=$(grep "^# 🤖" "$ROBOTS" 2>/dev/null | head -1 | sed 's/^# 🤖 //')
    if [ -n "$current" ]; then
      echo "🤖 $current"
    else
      echo "No post yet."
    fi
  else
    echo "Usage: robotlove \"your message\""
    exit 1
  fi
  exit 0
fi

MSG="# 🤖 $1"

if grep -q "^# 🤖" "$ROBOTS" 2>/dev/null; then
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "s|^# 🤖.*|$MSG|" "$ROBOTS"
  else
    sed -i "s|^# 🤖.*|$MSG|" "$ROBOTS"
  fi
else
  if [ ! -f "$ROBOTS" ]; then
    echo "Error: $ROBOTS not found"
    exit 1
  fi
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "1s|^|$MSG\n|" "$ROBOTS"
  else
    sed -i "1s|^|$MSG\n|" "$ROBOTS"
  fi
fi

echo "🤖 posted: \"$1\""
