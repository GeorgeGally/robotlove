#!/bin/bash
set -euo pipefail

CONF="$HOME/.robotlove_conf"

load_robots_path() {
  if [ -f "$CONF" ]; then
    ROBOTS=$(grep '^ROBOTS=' "$CONF" | head -1 | cut -d= -f2-)
    if [ -n "$ROBOTS" ] && [ -f "$ROBOTS" ]; then
      return 0
    fi
  fi
  # auto-detect common locations
  for candidate in \
    "$HOME/public_html/robots.txt" \
    "$HOME/www/robots.txt" \
    "/var/www/html/robots.txt" \
    "/var/www/robots.txt"; do
    if [ -f "$candidate" ]; then
      ROBOTS="$candidate"
      return 0
    fi
  done
  echo "Error: robots.txt not found. Run: robotlove setup /path/to/robots.txt" >&2
  exit 1
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-' | tr -s '-' | sed 's/^-//;s/-$//'
}

read_post() {
  python3 - "$1" <<'PYEOF'
import sys, re
path = sys.argv[1]
try:
    content = open(path).read()
except Exception:
    sys.exit(0)
lines = content.split('\n')
in_block = False
paths = []
for line in lines:
    s = line.strip()
    if re.match(r'^user-agent:\s*robotlove$', s, re.I):
        in_block = True
        continue
    if not in_block:
        continue
    if re.match(r'^user-agent:', s, re.I):
        break
    if s == '' and paths:
        break
    if re.match(r'^disallow:', s, re.I):
        p = s.split(':', 1)[1].strip()
        if p:
            paths.append(p)
for p in paths:
    print(p)
PYEOF
}

write_post() {
  python3 - "$1" "$2" <<'PYEOF'
import sys, re, os, tempfile, shutil
path, disallow = sys.argv[1], sys.argv[2]
block = f'User-agent: Robotlove\nDisallow: {disallow}\n\n'
try:
    content = open(path).read()
except FileNotFoundError:
    print(f'Error: {path} not found', file=sys.stderr)
    sys.exit(1)
# remove existing Robotlove block, preserve everything else
content = re.sub(r'(?i)User-agent:\s*Robotlove\n(?:Disallow:[^\n]*\n)*\n?', '', content)
content = block + content.lstrip('\n')
# atomic write
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))
try:
    with os.fdopen(fd, 'w') as f:
        f.write(content)
    shutil.move(tmp, path)
except Exception as e:
    if os.path.exists(tmp):
        os.unlink(tmp)
    print(f'Error writing: {e}', file=sys.stderr)
    sys.exit(1)
PYEOF
}

# --- commands ---

if [ "${1:-}" = "setup" ]; then
  if [ $# -lt 2 ]; then
    echo "Usage: robotlove setup /path/to/robots.txt" >&2
    exit 1
  fi
  if [ ! -f "$2" ]; then
    echo "Error: $2 not found" >&2
    exit 1
  fi
  echo "ROBOTS=$2" > "$CONF"
  echo "🤖 configured: $2"
  exit 0
fi

if [ "${1:-}" = "update" ]; then
  REPO_FILE="$HOME/.robotlove_repo"
  if [ ! -f "$REPO_FILE" ]; then
    echo "Error: repo path not saved. Re-run install.sh from the robotlove directory." >&2
    exit 1
  fi
  REPO=$(cat "$REPO_FILE")
  if [ ! -d "$REPO/.git" ]; then
    echo "Error: $REPO is not a git repo. Re-clone and run install.sh." >&2
    exit 1
  fi
  cd "$REPO"
  git pull
  DEST=$(command -v robotlove 2>/dev/null || echo "$HOME/bin/robotlove")
  cp cli/robotlove "$DEST"
  chmod +x "$DEST"
  echo "🤖 updated."
  exit 0
fi

load_robots_path

if [ $# -eq 0 ]; then
  result=$(read_post "$ROBOTS")
  if [ -n "$result" ]; then
    echo "🤖 $result"
  else
    echo "No post yet."
  fi
  exit 0
fi

SLUG="/$(slugify "$1")/"
write_post "$ROBOTS" "$SLUG"
echo "🤖 posted: $SLUG"
